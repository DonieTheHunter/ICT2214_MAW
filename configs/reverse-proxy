server {
    listen 443 ssl;
    server_name 192.168.246.139;
    ssl_certificate		/etc/https_cert/monitor.crt;
    ssl_certificate_key		/etc/https_cert/monitor.key;
        
    location / {
        mirror /_uploads_copy;
        proxy_pass https://10.0.0.10:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
	
	proxy_ssl_trusted_certificate /etc/https_cert/ca.crt;
	proxy_ssl_verify on;
	proxy_ssl_verify_depth 2;
	
	proxy_ssl_server_name on;
	proxy_ssl_name 10.0.0.10;

	proxy_set_header Content-Type $content_type;
	proxy_set_header Content_Length $content_length;
	proxy_pass_request_body on;
    }

    location /_uploads_copy {
        internal;
        proxy_pass http://192.168.246.139:6767/uploads_test;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
	    proxy_set_header Content-Type $content_type;
	    proxy_set_header Content_Length $content_length;
	    proxy_pass_request_body on;
    }
    access_log /var/log/nginx/reverse-proxy-access.log new_log_format;
    access_log /var/log/nginx/raw_access.log;
    error_log /var/log/nginx/reverse-proxy-error.log;
}
